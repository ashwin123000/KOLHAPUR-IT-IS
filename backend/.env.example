# ============================================================
# AI HIRING OS — Environment Variables Template
# Master Prompt V2.0
# 
# Copy this file to .env and fill in all values
# CRITICAL: All values are REQUIRED (no optional vars in production)
# ============================================================

# ============================================================
# DATABASE
# ============================================================
# Example (local):
# DATABASE_URL=postgresql://hiring_user:password123@localhost:5432/hiring_os
# Example (Docker):
# DATABASE_URL=postgresql://hiring_user:password123@postgres:5432/hiring_os
DATABASE_URL=postgresql://user:password@localhost:5432/hiring_os

# ============================================================
# REDIS
# ============================================================
# Example (local):
# REDIS_URL=redis://localhost:6379/0
# Example (Docker):
# REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ============================================================
# AUTHENTICATION
# ============================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-here-min-32-chars-12345678

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# AI/LLM
# ============================================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

LLM_MODEL=claude-sonnet-4-20250514

# ============================================================
# DOCKER (for VM sessions)
# ============================================================
# Linux:
# DOCKER_SOCKET=/var/run/docker.sock
# Windows (WSL2):
# DOCKER_SOCKET=\\.\pipe\docker_engine
DOCKER_SOCKET=/var/run/docker.sock

VM_IMAGE_NAME=hiring-vm:latest
VM_PORT_RANGE_START=8100
VM_PORT_RANGE_END=9000

# ============================================================
# FILE STORAGE
# ============================================================
# Local directory for uploads (create if doesn't exist)
UPLOAD_DIR=/uploads
MAX_UPLOAD_SIZE_MB=10

# ============================================================
# ENVIRONMENT & LOGGING
# ============================================================
ENVIRONMENT=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ============================================================
# EXTERNAL APIS
# ============================================================
# Get from: https://developer.adzuna.com/ (free, 1000 req/day)
ADZUNA_APP_ID=your-app-id
ADZUNA_API_KEY=your-api-key

# ============================================================
# EMBEDDING MODEL
# ============================================================
# sentence-transformers model (downloads on first use)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ============================================================
# KAGGLE (optional, for downloading datasets)
# ============================================================
# Get from: https://www.kaggle.com/settings/account
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ============================================================
# DATA DIRECTORIES
# ============================================================
# CSVs downloaded from Kaggle, IMF, PwC
DATA_RAW_DIR=/data/raw
DATA_PROCESSED_DIR=/data/processed
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── OTP ───────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5

# ── Auth Rate Limiting ────────────────────────────────────────
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Optional integrations ─────────────────────────────────────
# OPENAI_API_KEY=sk-...
# WEBHOOK_URL=https://...
